{
  "schemaVersion": 1,
  "id": "higher-ground",
  "displayName": "Higher Ground",
  "description": "Higher Ground required assets staged for the NWN EE bridge.",
  "requiredSourcePath": "HG REQUIRED FILES",
  "localBuildRoot": "C:/nwnbridge/assets",
  "stagingSubdir": "higher-ground",
  "legacyAssetRoots": [
    "hg-bridge-assets"
  ],
  "sourceArchives": [
    {
      "pattern": "hghak_std-beta28*.rar",
      "required": true,
      "description": "Higher Ground standard hak/tlk archive."
    },
    {
      "pattern": "cep_23_full_c*.7z",
      "required": true,
      "allowExistingStaged": true,
      "description": "CEP 2.3 full archive. Existing staged CEP may be used when this archive is a zero-byte placeholder."
    }
  ],
  "hakOrderTopFirst": [
    "cep2_custom",
    "cep2_top_v23",
    "cep2_add_phenos5",
    "cep2_add_phenos4",
    "cep2_add_phenos3",
    "cep2_add_phenos2",
    "cep2_add_phenos1",
    "cep2_add_loads",
    "cep2_add_rules",
    "cep2_add_sb_v1",
    "cep2_core6",
    "cep2_core5",
    "cep2_core4",
    "cep2_core3",
    "cep2_core2",
    "cep2_core1",
    "cep2_core0",
    "cep2_add_doors",
    "cep2_add_tiles2",
    "cep2_add_tiles1",
    "cep2_ext_tiles",
    "cep2_add_skies",
    "cep2_crp"
  ],
  "tlkFiles": [
    "cep22_v1.tlk",
    "cep23_v1.tlk",
    "dialog.tlk"
  ],
  "overrideRoots": [
    "hg-override/override",
    "hg-overlay/override"
  ],
  "compatibilityFixes": [
    {
      "id": "hg-ee-generated-missing-class-package-2das",
      "kind": "generatedMissingClassPackage2das",
      "sourceHak": "cep2_custom.hak",
      "sourceResource": "classes.2da",
      "resourceColumns": [
        "FeatsTable",
        "SkillsTable",
        "BonusFeatsTable",
        "PreReqTable"
      ],
      "resourceNames": [
        "CLS_FEAT_EYEOFG",
        "CLS_SKILL_EYEOFG",
        "CLS_BFEAT_EYEOFG",
        "CLS_PRES_EYEOFG",
        "CLS_FEAT_SHOUDI",
        "CLS_SKILL_SHOUDI",
        "CLS_BFEAT_SHOUDI",
        "CLS_PRES_SHOUDI"
      ],
      "evidence": "HG cep2_custom.hak classes.2da references these CEP prestige-package tables, but the provided HG/CEP required files do not contain them. EE demands the referenced class package 2DAs during module load; Diamond tolerates the absent resources for existing characters. Generate empty package tables as loader-safe EE compatibility resources without adding feats, skills, or prerequisites."
    },
    {
      "id": "hg-ee-ttr01-orientation",
      "kind": "erfTextResourcePatch",
      "sourceHak": "cep2_ext_tiles.hak",
      "resource": "ttr01.set",
      "tile": "TILE625",
      "insertAfterPrefix": "WalkMesh=",
      "line": "Orientation=0",
      "evidence": "EE tileset loader requires Orientation in each TILE block; CEP legacy ttr01.set TILE625 omits it."
    }
  ],
  "nwsync": {
    "name": "HG Bridge Required Assets",
    "description": "Higher Ground required assets plus EE compatibility resources for the NWN EE bridge.",
    "groupId": 213,
    "url": "http://127.0.0.1:5122/",
    "repositoryPath": "C:/nwnbridge/nwsync/higher-ground/repository",
    "limitFileSizeMB": 1024,
    "maxManifestTotalBytes": 3900000000,
    "compression": "none",
    "writeOrigins": true
  }
}
